generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// SCRAPE LOG (ETL Tracker)
model ScrapeLog {
    id           String   @id @default(uuid())
    entityType   String   // "contract" or "person"
    entityId     String   // The viespirkiai ID (jarKodas or contractId)
    status       String   // "pending", "success", "error"
    lastFetched  DateTime @default(now())
    retryCount   Int      @default(0)

    @@unique([entityType, entityId])
}

// ENTITY RESOLUTION - Core Nodes
model Company {
    jarKodas    String   @id
    name        String
    normalized  String   // Soundex/Metaphone search key
    riskScore   Float    @default(0)
    displayScore Float   @default(0) // log2(riskScore + 1) * 10
    updatedAt   DateTime @updatedAt

    // Enrichment fields (populated by db:enrich from /asmuo/{jar}.json)
    legalForm           String?
    address             String?
    registeredAt        DateTime?
    status              String?   // e.g. "Veikianti", "Likviduota"
    statusSince         DateTime?
    dataAsOf            DateTime? // jar.duomenuData — freshness indicator
    employeeCount       Int?      // sodra.draustieji
    avgSalary           Float?    // sodra.vidutinisAtlyginimas (EUR)
    monthlyContributions Float?   // sodra.imokuSuma (EUR)
    totalSalaryExpenses  Float?   // sodra.atlyginimuIslaidos (EUR)
    vehicleCount        Int?      // regitra.rows

    // Edges
    contracts        Contract[]           @relation("Supplier")
    relationships    PersonRelationship[]
    sodraHistory     SodraHistory[]
    courtRecords     CourtRecord[]
    procurementYears ProcurementYear[]
    topCounterparties TopCounterparty[]
}

// Monthly SODRA (social insurance) history — from sodra.duomenys[]
model SodraHistory {
    id            String   @id @default(uuid())
    companyId     String
    month         DateTime // first day of the month (e.g. 2024-01-01)
    employees     Int
    avgSalary     Float
    contributions Float

    company       Company  @relation(fields: [companyId], references: [jarKodas], onDelete: Cascade)

    @@unique([companyId, month])
}

// Court records — from teismoNuosprendziai.nuosprendziai[]
model CourtRecord {
    id           String   @id @default(uuid())
    companyId    String
    caseNumber   String
    caseType     String   // e.g. "Civilinė byla", "Administracinė byla"
    date         DateTime
    court        String
    roleInCase   String   // "Atsakovas", "Ieškovas", "Trečiasis asmuo"
    citationCount Int     @default(0)
    documentUrl  String?

    company      Company  @relation(fields: [companyId], references: [jarKodas], onDelete: Cascade)

    @@unique([companyId, caseNumber])
}

// Annual procurement totals — from sutartys.pirkimaiKasMetus[] and tiekimaiKasMetus[]
model ProcurementYear {
    id            String  @id @default(uuid())
    companyId     String
    year          Int
    asBuyerEur    Float   @default(0)
    asSupplierEur Float   @default(0)

    company       Company @relation(fields: [companyId], references: [jarKodas], onDelete: Cascade)

    @@unique([companyId, year])
}

// Top contract counterparties — from sutartys.topPirkejai[] / topTiekejai[]
model TopCounterparty {
    id                String  @id @default(uuid())
    companyId         String
    counterpartyJar   String
    counterpartyName  String
    totalEur          Float
    contractCount     Int
    role              String  // "buyer" (they bought from us) or "supplier" (they sold to us)

    company           Company @relation(fields: [companyId], references: [jarKodas], onDelete: Cascade)

    @@unique([companyId, counterpartyJar, role])
}

model Person {
    uid         String   @id // Synthetic ID: H(normalized_name)
    fullName    String
    normalized  String   // Surname normalization for Lithuanian variations
    riskScore   Float    @default(0)
    displayScore Float   @default(0)
    updatedAt   DateTime @updatedAt

    // Edges
    relationships PersonRelationship[]
}

// EDGES (RAGp Projection)
model Contract {
    contractId  String   @id
    title       String
    value       Float
    currency    String   @default("EUR")
    status      String
    signedAt    DateTime
    
    // Edge: Institution -> Company
    buyerName   String
    buyerCode   String
    supplierId  String
    supplier    Company  @relation("Supplier", fields: [supplierId], references: [jarKodas])
}

model PersonRelationship {
    id          String   @id @default(uuid())
    personId    String
    companyId   String
    role        String   // "owner", "ceo", "ubo"
    since       DateTime?
    until       DateTime?

    person      Person   @relation(fields: [personId], references: [uid])
    company     Company  @relation(fields: [companyId], references: [jarKodas])

    @@unique([personId, companyId, role])
}
